{
  "name": "GitHub",
  "short_name": "GitHub",
  "scope": "https://github.com/",
  "start_url": "https://github.com/",
  "display": "standalone",
  "display_override": ["tabbed"],
  "tab_strip": {
    "home_tab": {
      "scope_patterns": [{ "pathname": "/" }]
    },
    "new_tab_button": {
      "url": "/matthewkeating?tab=repositories&q=&type=&language=&sort=name"
    }
  },
  "icons": [
    {
      "src": "https://github.githubassets.com/assets/app-icon-512-7f9c4ff2e960.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    }
  ],
  "prefer_related_applications": true,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.github.android",
      "id": "com.github.android"
    }
  ]
}