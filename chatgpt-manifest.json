{
  "name": "ChatGPT",
  "short_name": "ChatGPT",
  "scope": "https://chatgpt.com/",
  "start_url": "https://chatgpt.com/",
  "display": "standalone",
  "display_override": ["tabbed"],
  "tab_strip": {
    "home_tab": {
      "scope_patterns": [{ "pathname": "/" }]
    },
    "new_tab_button": {
      "url": "https://chatgpt.com/"
    }
  },
  "theme_color": "#000000",
  "background_color": "#ffffff",
  "icons": [
    {
      "src": "https://chatgpt.com/images/chatgpt-icon-192x192.png",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    },
    {
      "src": "https://chatgpt.com/images/chatgpt-icon-512x512.png",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    }
  ],
  "prefer_related_applications": true,
  "related_applications": [
    {
      "platform": "play",
      "id": "com.openai.chatgpt",
      "url": "https://play.google.com/store/apps/details?id=com.openai.chatgpt&utm_source=android_chrome_manifest"
    }
  ]
}